{
  "name": "sidebar-skeleton-compostrap",
  "version": "3.0.3",
  "type": "module",
  "description": "Simple and fast sidebar skeleton built on Bootstrap 5.",
  "license": "MIT",
  "keywords": [
    "sidebar",
    "menu",
    "bootstrap"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./sidebar": "./dist/sidebar.js",
    "./sidebar.css": "./dist/sidebar.css",
    "./src/scss/*": "./src/scss/*"
  },
  "dependencies": {
    "theme-switcher-compostrap": "^1.0.2"
  },
  "devDependencies": {
    "sass": "^1.97.1",
    "vite": "^8.0.16"
  },
  "peerDependencies": {
    "bootstrap": "^5.3.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:css",
    "build:css": "node scripts/build-css.js"
  }
}
